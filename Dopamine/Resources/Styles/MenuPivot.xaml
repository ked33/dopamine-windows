<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:animation="clr-namespace:Dopamine.Core.Settings;assembly=Dopamine.Core"
                    xmlns:dc="clr-namespace:Digimezzo.Foundation.WPF.Controls;assembly=Digimezzo.Foundation.WPF">

    <Style TargetType="{x:Type dc:Pivot}">
        <Setter Property="Duration" Value="{Binding Source={x:Static animation:UiAnimationSettings.Instance}, Path=StandardDurationSeconds}"/>
        <Setter Property="SlideFadeInDuration" Value="{Binding Source={x:Static animation:UiAnimationSettings.Instance}, Path=StandardDurationSeconds}"/>
    </Style>

    <Style TargetType="{x:Type dc:SlidingContentControl}">
        <Setter Property="Duration" Value="{Binding Source={x:Static animation:UiAnimationSettings.Instance}, Path=StandardDurationSeconds}"/>
        <Setter Property="SlideFadeInDuration" Value="{Binding Source={x:Static animation:UiAnimationSettings.Instance}, Path=StandardDurationSeconds}"/>
    </Style>

    <Style x:Key="MenuPivot" TargetType="{x:Type dc:Pivot}" BasedOn="{StaticResource {x:Type dc:Pivot}}">
        <Setter Property="IndicatorHeight" Value="2"/>
        <Setter Property="IndicatorBackground" Value="{DynamicResource Brush_Accent}"/>
    </Style>
    
    <Style x:Key="MenuPivotItem" TargetType="{x:Type dc:PivotItem}">
        <Setter Property="Padding" Value="10,14,10,14"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="HeaderFontSize" Value="15"/>
        <Setter Property="HeaderForeground" Value="{DynamicResource Brush_SecondaryText}"/>
        <Setter Property="SelectedHeaderForeground" Value="{DynamicResource Brush_PrimaryText}"/>
    </Style>
</ResourceDictionary>
