<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:animation="clr-namespace:Dopamine.Core.Settings;assembly=Dopamine.Core">

    <Style x:Key="SubMenuSlideInAnimation" TargetType="{x:Type Panel}">
        <Style.Triggers>
            <Trigger Property="Visibility" Value="Visible">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard SpeedRatio="{Binding Source={x:Static animation:UiAnimationSettings.Instance}, Path=StoryboardSpeedRatio}">
                            <ThicknessAnimation  
                                Storyboard.TargetProperty="Margin"
                                From="-10,0,0,0" To="0,0,0,0" Duration="0:0:0.5" />
                            <DoubleAnimation  
                                Storyboard.TargetProperty="Opacity"
                                From="0.0" To="1.0" Duration="0:0:1" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
