<UserControl x:Class="Dopamine.Views.FullPlayer.Settings.SettingsOnline"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dc="clr-namespace:Digimezzo.Foundation.WPF.Controls;assembly=Digimezzo.Foundation.WPF"
             xmlns:utils="clr-namespace:Dopamine.Utils"
             xmlns:prismMvvm="clr-namespace:Prism.Mvvm;assembly=Prism.Wpf"
             Loaded="SettingsOnline_Loaded"
             Unloaded="SettingsOnline_Unloaded"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             prismMvvm:ViewModelLocator.AutoWireViewModel="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5" Padding="15" PanningMode="Both">
        <StackPanel>
            <Label Style="{StaticResource TitleLabel}" Content="{DynamicResource Language_Netease_Music}" />
            <TextBlock Margin="0,5,0,0" Text="{DynamicResource Language_Netease_Online_Description}" Foreground="{DynamicResource Brush_PrimaryText}" TextWrapping="Wrap"/>
            <Grid Margin="0,15,0,0" MaxWidth="620" HorizontalAlignment="Left">
                <Grid VerticalAlignment="Top" Visibility="{Binding IsNeteaseSignedIn, Converter={StaticResource InvertingBooleanToCollapsedConverter}}">
                    <dc:Pivot Style="{DynamicResource MenuPivot}" SelectedIndex="{Binding SelectedNeteaseLoginMethod}" MaxHeight="260" VerticalAlignment="Top" VerticalContentAlignment="Top">
                        <dc:PivotItem Header="{DynamicResource Language_Netease_Qr_Login}" Style="{StaticResource MenuPivotItem}">
                            <Grid Margin="0,8,0,0" VerticalAlignment="Top" IsEnabled="{Binding IsNeteaseSigningIn, Converter={StaticResource InvertingBooleanConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="180" Height="180" Background="White" Padding="8" VerticalAlignment="Top">
                                    <Grid>
                                        <Image Source="{Binding NeteaseQrCodeImage}" Stretch="Uniform"/>
                                        <dc:ProgressRing Width="48" Height="48" Foreground="{DynamicResource Brush_Accent}" IsActive="{Binding IsNeteaseSigningIn}"/>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Language_Netease_Scan_With_App}" Foreground="{DynamicResource Brush_PrimaryText}" TextWrapping="Wrap"/>
                                    <TextBlock Margin="0,10,0,0" Text="{Binding NeteaseStatusText}" Foreground="{DynamicResource Brush_SecondaryText}" TextWrapping="Wrap"/>
                                    <Button Margin="0,10,0,0" HorizontalAlignment="Left" Style="{StaticResource RegularButton}" Content="{DynamicResource Language_Netease_Refresh_Qr}" Command="{Binding RefreshNeteaseQrCommand}"/>
                                </StackPanel>
                            </Grid>
                        </dc:PivotItem>
                        <dc:PivotItem Header="{DynamicResource Language_Netease_Cookie_Login}" Style="{StaticResource MenuPivotItem}">
                            <StackPanel Margin="0,15,0,0" IsEnabled="{Binding IsNeteaseSigningIn, Converter={StaticResource InvertingBooleanConverter}}">
                                <TextBlock Text="{DynamicResource Language_Netease_Cookie_Description}" Foreground="{DynamicResource Brush_PrimaryText}" TextWrapping="Wrap"/>
                                <PasswordBox x:Name="NeteaseCookiePasswordBox" Margin="0,12,0,0" MaxWidth="520" HorizontalAlignment="Stretch" Style="{StaticResource MetroPasswordBox}"/>
                                <StackPanel Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Margin="0,0,15,0" VerticalAlignment="Center" Text="{Binding NeteaseStatusText}" Foreground="{DynamicResource Brush_SecondaryText}" TextWrapping="Wrap"/>
                                    <Button Style="{StaticResource RegularButtonAccent}" Content="{DynamicResource Language_Netease_Validate_And_Login}" Click="NeteaseCookieLogin_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </dc:PivotItem>
                    </dc:Pivot>
                </Grid>
                <StackPanel Visibility="{Binding IsNeteaseSignedIn, Converter={StaticResource BooleanToCollapsedConverter}}">
                    <DockPanel>
                        <TextBlock Text="&#xE8FB;" Style="{StaticResource SegoeAssets}" Foreground="{DynamicResource Brush_Accent}" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Margin="10,0,0,0" Foreground="{DynamicResource Brush_Accent}" VerticalAlignment="Center">
                            <Run Text="{DynamicResource Language_Netease_Signed_In_As}"/><Run Text=" "/><Run Text="{Binding NeteaseAccountDisplay, Mode=OneWay}"/>
                        </TextBlock>
                    </DockPanel>
                    <TextBlock Margin="0,8,0,0" Text="{DynamicResource Language_Netease_Session_Encrypted}" Foreground="{DynamicResource Brush_SecondaryText}" TextWrapping="Wrap"/>
                    <Button Margin="0,12,0,0" HorizontalAlignment="Left" Style="{StaticResource RegularButton}" Content="{DynamicResource Language_Sign_Out}" Command="{Binding NeteaseLogoutCommand}"/>
                </StackPanel>
            </Grid>
            <StackPanel Margin="0,15,0,0" MaxWidth="620" HorizontalAlignment="Left">
                <TextBlock Text="{DynamicResource Language_Netease_Audio_Quality}" Foreground="{DynamicResource Brush_PrimaryText}"/>
                <ComboBox Margin="0,8,0,0" Width="220" HorizontalAlignment="Left" Style="{StaticResource MetroComboBox}"
                          ItemsSource="{Binding NeteaseAudioQualityOptions}"
                          SelectedIndex="{Binding SelectedNeteaseAudioQuality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Margin="0,8,0,0" Text="{DynamicResource Language_Netease_Audio_Quality_Description}" Foreground="{DynamicResource Brush_SecondaryText}" TextWrapping="Wrap"/>
            </StackPanel>
            <Label Margin="0,20,0,0" Style="{StaticResource TitleLabel}" Content="{DynamicResource Language_Netease_Download_Title}" />
            <StackPanel MaxWidth="620" HorizontalAlignment="Left">
                <TextBlock Text="{DynamicResource Language_Netease_Download_Directory}" Foreground="{DynamicResource Brush_PrimaryText}"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Style="{StaticResource MetroTextBox}"
                             IsReadOnly="True"
                             Text="{Binding DownloadDirectory, Mode=OneWay}"
                             MinWidth="360"/>
                    <Button Grid.Column="1"
                            Margin="10,0,0,0"
                            Style="{StaticResource RegularButton}"
                            Content="{DynamicResource Language_Netease_Download_Choose_Directory}"
                            Command="{Binding BrowseDownloadDirectoryCommand}"/>
                    <Button Grid.Column="2"
                            Margin="10,0,0,0"
                            Style="{StaticResource RegularButton}"
                            Content="{DynamicResource Language_Netease_Download_Open_Directory}"
                            Command="{Binding OpenDownloadDirectoryCommand}"/>
                </Grid>
                <TextBlock Margin="0,8,0,0"
                           Text="{DynamicResource Language_Netease_Download_Directory_Description}"
                           Foreground="{DynamicResource Brush_SecondaryText}"
                           TextWrapping="Wrap"/>
                <TextBlock Margin="0,14,0,0"
                           Text="{DynamicResource Language_Netease_Download_Source_Priority}"
                           Foreground="{DynamicResource Brush_PrimaryText}"/>
                <ComboBox Margin="0,8,0,0"
                          Width="260"
                          HorizontalAlignment="Left"
                          Style="{StaticResource MetroComboBox}"
                          ItemsSource="{Binding DownloadSourcePriorityOptions}"
                          SelectedIndex="{Binding SelectedDownloadSourcePriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Margin="0,8,0,0"
                           Text="{DynamicResource Language_Netease_Download_Source_Priority_Description}"
                           Foreground="{DynamicResource Brush_SecondaryText}"
                           TextWrapping="Wrap"/>
            </StackPanel>
            <Label Margin="0,20,0,0" Style="{StaticResource TitleLabel}" Content="UnblockNeteaseMusic" />
            <TextBlock Margin="0,5,0,0" MaxWidth="620" HorizontalAlignment="Left" Text="{DynamicResource Language_Netease_Unblock_Description}" Foreground="{DynamicResource Brush_PrimaryText}" TextWrapping="Wrap"/>
            <TextBlock Margin="0,8,0,0" MaxWidth="620" HorizontalAlignment="Left" Text="{DynamicResource Language_Netease_Unblock_Risk_Notice}" Foreground="{DynamicResource Brush_SecondaryText}" TextWrapping="Wrap"/>
            <dc:Windows10ToggleSwitch Margin="0,12,0,0" HorizontalAlignment="Left" FontSize="12" OnLabel="{DynamicResource Language_Yes}" OffLabel="{DynamicResource Language_No}" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxEnableUnblockNeteaseMusic}"/>
            <StackPanel Margin="0,12,0,0" IsEnabled="{Binding CheckBoxEnableUnblockNeteaseMusic}">
                <TextBlock Text="{DynamicResource Language_Netease_Unblock_Sources}" Foreground="{DynamicResource Brush_PrimaryText}"/>
                <UniformGrid Margin="0,8,0,0" Columns="3" Width="450" HorizontalAlignment="Left">
                    <dc:Windows10ToggleSwitch HorizontalAlignment="Left" FontSize="12" OnLabel="Kugou" OffLabel="Kugou" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxUnblockKugou}"/>
                    <dc:Windows10ToggleSwitch HorizontalAlignment="Left" FontSize="12" OnLabel="Bodian" OffLabel="Bodian" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxUnblockBodian}"/>
                    <dc:Windows10ToggleSwitch HorizontalAlignment="Left" FontSize="12" OnLabel="Kuwo" OffLabel="Kuwo" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxUnblockKuwo}"/>
                </UniformGrid>
                <TextBlock Margin="0,12,0,0" Text="{DynamicResource Language_Netease_Unblock_Audio_Quality}" Foreground="{DynamicResource Brush_PrimaryText}" TextWrapping="Wrap"/>
                <ComboBox Margin="0,8,0,0" Width="220" HorizontalAlignment="Left" Style="{StaticResource MetroComboBox}"
                          ItemsSource="{Binding UnblockAudioQualityOptions}"
                          SelectedIndex="{Binding SelectedUnblockAudioQuality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Margin="0,8,0,0" MaxWidth="620" HorizontalAlignment="Left" Text="{DynamicResource Language_Netease_Unblock_Audio_Quality_Description}" Foreground="{DynamicResource Brush_SecondaryText}" TextWrapping="Wrap"/>
                <Grid Margin="0,12,0,0" MaxWidth="620" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Brush_SecondaryText}" Text="{Binding UnblockStatusText}" TextWrapping="Wrap"/>
                    <Button Grid.Column="1" Margin="15,0,0,0" Style="{StaticResource RegularButton}" Content="{DynamicResource Language_Netease_Unblock_Restart}" Command="{Binding RestartUnblockSidecarCommand}"/>
                </Grid>
                <StackPanel.Style>
                    <Style>
                        <Style.Triggers>
                            <Trigger Property="StackPanel.IsEnabled" Value="False">
                                <Setter Property="StackPanel.Opacity" Value="0.5" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
            </StackPanel>
            <Label Margin="0,20,0,0" Style="{StaticResource TitleLabel}" Content="{DynamicResource Language_Search_Online}" />
            <TextBlock Margin="0,5,0,0" Text="{DynamicResource Language_Add_Remove_Online_Search_Providers}" Foreground="{DynamicResource Brush_PrimaryText}"/>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <ListBox Style="{StaticResource MetroListBox}" Width="300" ItemsSource="{Binding SearchProviders}" SelectedItem="{Binding SelectedSearchProvider}"/>
                <StackPanel Margin="10,0,0,0">
                    <StackPanel.Resources>
                        <utils:BindingProxy x:Key="RemoveProxy" Data="{DynamicResource Language_Remove}"/>
                    </StackPanel.Resources>
                    <Button Style="{StaticResource RegularButton}" MinWidth="100" Margin="0,0,0,10" Content="{DynamicResource Language_Add}" Command="{Binding AddCommand}"/>
                    <Button Style="{StaticResource RegularButton}" MinWidth="100" Margin="0,0,0,10" Content="{DynamicResource Language_Edit}" Command="{Binding EditCommand}"/>
                    <Button Style="{StaticResource RegularButton}" MinWidth="100" Content="{Binding Source={StaticResource RemoveProxy}, Path=Data,Converter={StaticResource AddEllipsisConverter}}" Command="{Binding RemoveCommand}"/>
                </StackPanel>
            </StackPanel>
            <Label Margin="0,20,0,0" Style="{StaticResource TitleLabel}" Content="Last.fm" />
            <TextBlock Margin="0,5,0,0" Text="{DynamicResource Language_Sign_In_To_Enable_Lastfm}" Foreground="{DynamicResource Brush_PrimaryText}"/>
            <Button Style="{StaticResource LinkButton}" Margin="0,5,0,0" Foreground="{DynamicResource Brush_Accent}" Content="{DynamicResource Language_Create_A_Lastfm_Account}" Command="{Binding CreateLastFmAccountCommand}"/>
            <Grid Width="300" HorizontalAlignment="Left" Margin="0,15,0,0">
                <Grid.Style>
                    <Style>
                        <Style.Triggers>
                            <Trigger Property="StackPanel.IsHitTestVisible" Value="False">
                                <Setter Property="StackPanel.Opacity" Value="0.5" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Viewbox Panel.ZIndex="1" Width="40" Height="40" Visibility="{Binding IsLastFmSigningIn,Converter={StaticResource BooleanToCollapsedConverter}}">
                    <dc:ProgressRing Foreground="{DynamicResource Brush_Accent}" IsActive="{Binding IsLastFmSigningIn}"/>
                </Viewbox>
                <StackPanel IsHitTestVisible="{Binding IsLastFmSigningIn, Converter={StaticResource InvertingBooleanConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Language_Username}" Foreground="{DynamicResource Brush_PrimaryText}"/>
                        <TextBox Grid.Row="0" Grid.Column="2" Style="{StaticResource MetroTextBox}" Text="{Binding LastFmUsername}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Language_Password}" Foreground="{DynamicResource Brush_PrimaryText}"/>
                        <PasswordBox x:Name="PasswordBox" Grid.Row="2" Grid.Column="2" Style="{StaticResource MetroPasswordBox}" PasswordChanged="PasswordBox_PasswordChanged"/>
                    </Grid>
                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Grid HorizontalAlignment="Right" Margin="0,0,10,0">
                            <DockPanel Visibility="{Binding IsLastFmSignedIn, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Right">
                                <TextBlock 
                                x:Name="SuccessIcon"
                                Text="&#xE8FB;"
                                Style="{StaticResource SegoeAssets}"
                                DockPanel.Dock="Left" 
                                VerticalAlignment="Center" 
                                Foreground="{DynamicResource Brush_Accent}" 
                                FontSize="14" />
                                <TextBlock Margin="10,0,0,0" Foreground="{DynamicResource Brush_Accent}" Text="{DynamicResource Language_Signed_In}" VerticalAlignment="Center"/>
                            </DockPanel>
                            <DockPanel Visibility="{Binding IsLastFmSignInError, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Right">
                                <TextBlock 
                                x:Name="FailureIcon"
                                Text="&#xE10A;"
                                Style="{StaticResource SegoeAssets}"
                                DockPanel.Dock="Left" 
                                VerticalAlignment="Center" 
                                Foreground="{DynamicResource Brush_Accent}" 
                                FontSize="14" />
                                <TextBlock Margin="10,0,0,0" Foreground="{DynamicResource Brush_Accent}" Text="{DynamicResource Language_Sign_In_Failed}" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Grid>
                        <Grid>
                            <Button Style="{StaticResource RegularButton}" HorizontalAlignment="Right" Content="{DynamicResource Language_Sign_In}" Command="{Binding LastfmSignInCommand}" Visibility="{Binding IsLastFmSignedIn, Converter={StaticResource InvertingBooleanToCollapsedConverter}}"/>
                            <Button Style="{StaticResource RegularButton}" HorizontalAlignment="Right" Content="{DynamicResource Language_Sign_Out}" Command="{Binding LastfmSignOutCommand}" Visibility="{Binding IsLastFmSignedIn, Converter={StaticResource BooleanToCollapsedConverter}}"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel.Style>
                        <Style>
                            <Style.Triggers>
                                <Trigger Property="StackPanel.IsHitTestVisible" Value="False">
                                    <Setter Property="StackPanel.Opacity" Value="0.5" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                </StackPanel>
            </Grid>
            <TextBlock Margin="0,20,0,0" Text="{DynamicResource Language_Download_Artist_Information_From_Lastfm_Automatically}" Foreground="{DynamicResource Brush_PrimaryText}"/>
            <dc:Windows10ToggleSwitch x:Name="CheckBoxDownloadArtistInformation" Margin="0,10,0,0" HorizontalAlignment="Left" FontSize="12" OnLabel="{DynamicResource Language_Yes}" OffLabel="{DynamicResource Language_No}" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxDownloadArtistInformationChecked}"/>
            <Label Margin="0,20,0,0" Style="{StaticResource TitleLabel}" Content="Discord" />
            <TextBlock Margin="0,5,0,0" Text="{DynamicResource Language_Enable_Discord_Rich_Presence}" Foreground="{DynamicResource Brush_PrimaryText}"/>
            <dc:Windows10ToggleSwitch x:Name="CheckBoxEnableDiscordRichPresence" Margin="0,10,0,0" HorizontalAlignment="Left" FontSize="12" OnLabel="{DynamicResource Language_Yes}" OffLabel="{DynamicResource Language_No}" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxEnableDiscordRichPresence}"/>
            <Label Margin="0,20,0,0" Style="{StaticResource TitleLabel}" Content="{DynamicResource Language_Lyrics}" />
            <TextBlock Margin="0,5,0,0" Text="{DynamicResource Language_Download_Lyrics_Automatically}" Foreground="{DynamicResource Brush_PrimaryText}"/>
            <dc:Windows10ToggleSwitch x:Name="CheckBoxDownloadLyrics" Margin="0,10,0,0" HorizontalAlignment="Left" FontSize="12" OnLabel="{DynamicResource Language_Yes}" OffLabel="{DynamicResource Language_No}" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxDownloadLyricsChecked}"/>
            <StackPanel Margin="0,20,0,0" IsHitTestVisible="{Binding CheckBoxDownloadLyricsChecked}">
                <TextBlock Text="{DynamicResource Language_Lyrics_Download_Timeout}" Foreground="{DynamicResource Brush_PrimaryText}"/>
                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <ComboBox x:Name="ComboBoxTimeout" Style="{StaticResource MetroComboBox}" Padding="0" HorizontalAlignment="Left" VerticalContentAlignment="Center" Width="100" ItemsSource="{Binding Timeouts}" SelectedItem="{Binding SelectedTimeout}"/>
                    <TextBlock Margin="10,0,0,0" Text="{DynamicResource Language_Seconds}" VerticalAlignment="Center" Foreground="{DynamicResource Brush_PrimaryText}"/>
                </StackPanel>
                <TextBlock Margin="0,20,0,0" Text="{DynamicResource Language_Download_Lyrics_From}" Foreground="{DynamicResource Brush_PrimaryText}"/>
                <UniformGrid Columns="3" Width="450" HorizontalAlignment="Left">
                    <dc:Windows10ToggleSwitch x:Name="CheckBoxChartLyrics" Margin="0,10,0,0" HorizontalAlignment="Left" FontSize="12" OnLabel="ChartLyrics" OffLabel="ChartLyrics" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxChartLyricsChecked}"/>
                    <dc:Windows10ToggleSwitch x:Name="CheckBoxLoloLyrics" Margin="0,10,0,0" HorizontalAlignment="Left" FontSize="12" OnLabel="LoloLyrics" OffLabel="LoloLyrics" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxLoloLyricsChecked}"/>
                    <dc:Windows10ToggleSwitch x:Name="CheckBoxMetroLyrics" Margin="0,10,0,0" HorizontalAlignment="Left" FontSize="12" OnLabel="MetroLyrics" OffLabel="MetroLyrics" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxMetroLyricsChecked}"/>
                    <dc:Windows10ToggleSwitch x:Name="CheckBoxXiamiLyrics" Margin="0,10,0,0" HorizontalAlignment="Left" FontSize="12" OnLabel="{DynamicResource Language_XiamiLyrics}" OffLabel="{DynamicResource Language_XiamiLyrics}" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxXiamiLyricsChecked}"/>
                    <dc:Windows10ToggleSwitch x:Name="CheckBoxNeteaseLyrics" Margin="0,10,0,0" HorizontalAlignment="Left" FontSize="12" OnLabel="{DynamicResource Language_NeteaseLyrics}" OffLabel="{DynamicResource Language_NeteaseLyrics}" Foreground="{DynamicResource Brush_PrimaryText}" Accent="{DynamicResource Brush_Accent}" IsChecked="{Binding CheckBoxNeteaseLyricsChecked}"/>
                </UniformGrid>
                <StackPanel.Style>
                    <Style>
                        <Style.Triggers>
                            <Trigger Property="StackPanel.IsHitTestVisible" Value="False">
                                <Setter Property="StackPanel.Opacity" Value="0.5" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
