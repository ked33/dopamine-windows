<UserControl x:Class="Dopamine.Views.FullPlayer.Collection.CollectionOnlineSearch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dc="clr-namespace:Digimezzo.Foundation.WPF.Controls;assembly=Digimezzo.Foundation.WPF"
             xmlns:pc="clr-namespace:Dopamine.Controls"
             xmlns:utils="clr-namespace:Dopamine.Utils"
             xmlns:prismMvvm="clr-namespace:Prism.Mvvm;assembly=Prism.Wpf"
             xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
             prismMvvm:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <utils:BindingProxy x:Key="OnlineSearchViewModelProxy" Data="{Binding}"/>
        <ContextMenu x:Key="OnlineSearchContextMenu"
                     x:Shared="False">
            <MenuItem Header="{DynamicResource Language_Jump_To_Playing_Song}"
                      InputGestureText="{DynamicResource Language_Ctrl_J}"
                      Click="JumpToPlayingMenuItem_Click"/>
            <Separator/>
            <MenuItem Header="{DynamicResource Language_Play_Selected}"
                      Command="{Binding Source={StaticResource OnlineSearchViewModelProxy}, Path=Data.PlaySelectedCommand}"/>
            <MenuItem Header="{DynamicResource Language_Play_Next}"
                      Command="{Binding Source={StaticResource OnlineSearchViewModelProxy}, Path=Data.PlayNextCommand}"/>
            <MenuItem Header="{DynamicResource Language_Add_To_Now_Playing}"
                      Command="{Binding Source={StaticResource OnlineSearchViewModelProxy}, Path=Data.AddToNowPlayingCommand}"/>
            <MenuItem Header="{DynamicResource Language_Song_Information}"
                      Command="{Binding Source={StaticResource OnlineSearchViewModelProxy}, Path=Data.ShowTrackInformationCommand}"/>
            <MenuItem Header="{DynamicResource Language_Download}"
                      Command="{Binding Source={StaticResource OnlineSearchViewModelProxy}, Path=Data.DownloadCommand}"/>
            <Separator/>
            <MenuItem Header="{DynamicResource Language_Search_Online}"
                      ItemsSource="{Binding Source={StaticResource OnlineSearchViewModelProxy}, Path=Data.ContextMenuSearchProviders}"
                      DisplayMemberPath="Name"
                      IsEnabled="{Binding Source={StaticResource OnlineSearchViewModelProxy}, Path=Data.HasContextMenuSearchProviders}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Foreground" Value="{DynamicResource Brush_ContextMenuText}"/>
                        <Setter Property="Command" Value="{Binding Source={StaticResource OnlineSearchViewModelProxy}, Path=Data.SearchOnlineCommand}"/>
                        <Setter Property="CommandParameter" Value="{Binding Id}"/>
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}"/>
        </i:EventTrigger>
        <i:EventTrigger EventName="Unloaded">
            <i:InvokeCommandAction Command="{Binding UnloadedCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <DockPanel Margin="10,20,10,26">
        <DockPanel DockPanel.Dock="Top" Margin="10,0,10,20">
            <Button DockPanel.Dock="Right"
                    Margin="10,0,0,0"
                    Style="{StaticResource RegularButtonAccent}"
                    Content="{DynamicResource Language_GdMusic_Search_Button}"
                    Command="{Binding SearchCommand}"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Text="{Binding Count}" FontSize="13" Foreground="{DynamicResource Brush_Accent}"/>
                <TextBlock Text="{DynamicResource Language_GdMusic_Result_Count}" FontSize="13" Margin="6,0,0,0" Foreground="{DynamicResource Brush_PrimaryText}"/>
            </StackPanel>
            <TextBox Style="{StaticResource MetroTextBox}"
                     VerticalAlignment="Center"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                </TextBox.InputBindings>
            </TextBox>
        </DockPanel>

        <Button DockPanel.Dock="Bottom"
                Margin="10,12,10,0"
                HorizontalAlignment="Center"
                Style="{StaticResource RegularButton}"
                Content="{DynamicResource Language_GdMusic_Load_More}"
                Command="{Binding LoadMoreCommand}"
                Visibility="{Binding IsLoadMoreVisible, Converter={StaticResource BooleanToCollapsedConverter}}"/>

        <Grid>
            <pc:DataGridEx x:Name="DataGridOnlineSearch"
                           Visibility="{Binding IsListVisible, Converter={StaticResource BooleanToCollapsedConverter}}"
                           ItemsSource="{Binding ItemsCvs.View}"
                           SelectedItem="{Binding SelectedItem}"
                           PreviewKeyDown="DataGridOnlineSearch_PreviewKeyDown"
                           KeyUp="DataGridOnlineSearch_KeyUp"
                           VirtualizingStackPanel.IsVirtualizing="True"
                           VirtualizingStackPanel.VirtualizationMode="Recycling">
                <pc:DataGridEx.Resources>
                    <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource DataGridRowStyle}">
                        <Setter Property="ContextMenu" Value="{StaticResource OnlineSearchContextMenu}"/>
                        <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick"/>
                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="DataGridRow_PreviewMouseRightButtonDown"/>
                    </Style>
                </pc:DataGridEx.Resources>
                <pc:DataGridEx.Columns>
                    <DataGridTextColumn Width="3*" SortMemberPath="TrackTitle" CellStyle="{StaticResource DataGridCellPrimaryWithEllipsis}" IsReadOnly="True" Binding="{Binding TrackTitle}">
                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Language_Song}"/></DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Width="40" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Label Style="{StaticResource PlaybackIndicator}" Visibility="{Binding IsPlaying, Converter={StaticResource BooleanToCollapsedConverter}}" Foreground="{DynamicResource Brush_Accent}" Margin="0,2,0,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="2*" SortMemberPath="ArtistName" CellStyle="{StaticResource DataGridCellPrimaryWithEllipsis}" IsReadOnly="True" Binding="{Binding ArtistName}">
                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Language_Artist}"/></DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="2*" SortMemberPath="AlbumTitle" CellStyle="{StaticResource DataGridCellPrimaryWithEllipsis}" IsReadOnly="True" Binding="{Binding AlbumTitle}">
                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Language_Album}"/></DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </pc:DataGridEx.Columns>
            </pc:DataGridEx>

            <dc:ProgressRing Width="60" Height="60" Foreground="{DynamicResource Brush_Accent}" IsActive="{Binding IsInitialSearching}" Visibility="{Binding IsInitialSearching, Converter={StaticResource BooleanToCollapsedConverter}}"/>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsPromptVisible, Converter={StaticResource BooleanToCollapsedConverter}}">
                <TextBlock FontSize="18" Foreground="{DynamicResource Brush_PrimaryText}" Text="{DynamicResource Language_GdMusic_Search_Prompt}" TextAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Brush_SecondaryText}" Text="{DynamicResource Language_GdMusic_Attribution}" TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsEmptyVisible, Converter={StaticResource BooleanToCollapsedConverter}}">
                <TextBlock FontSize="18" Foreground="{DynamicResource Brush_PrimaryText}" Text="{DynamicResource Language_GdMusic_No_Results}" TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsErrorVisible, Converter={StaticResource BooleanToCollapsedConverter}}">
                <TextBlock FontSize="18" Foreground="{DynamicResource Brush_PrimaryText}" Text="{Binding ErrorMessage}" TextAlignment="Center" TextWrapping="Wrap"/>
                <Button Margin="0,10,0,0" HorizontalAlignment="Center" Style="{StaticResource RegularButton}" Content="{DynamicResource Language_Retry}" Command="{Binding SearchCommand}"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
