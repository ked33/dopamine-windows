<UserControl x:Class="Dopamine.Views.Common.ProgressControlsThin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             xmlns:dc="clr-namespace:Digimezzo.Foundation.WPF.Controls;assembly=Digimezzo.Foundation.WPF"
             xmlns:prismMvvm="clr-namespace:Prism.Mvvm;assembly=Prism.Wpf"
             prismMvvm:ViewModelLocator.AutoWireViewModel="True">

    <Grid>
        <ProgressBar Height="2"
                     VerticalAlignment="Bottom"
                     BorderThickness="0"
                     Background="{DynamicResource Brush_SliderBackground}"
                     Foreground="{DynamicResource Brush_Accent}"
                     Opacity="0.55"
                     Panel.ZIndex="0"
                     IsHitTestVisible="False"
                     Maximum="1"
                     Value="{Binding BufferingProgressValue,Mode=OneWay}"
                     Visibility="{Binding ShowBufferingProgress, Converter={StaticResource BooleanToCollapsedConverter}}"/>
        <dc:UWPSliderHorizontalBottom x:Name="ProgressSliderThin" Panel.ZIndex="1" TrackBackground="Transparent" ButtonInnerBackground="{DynamicResource Brush_WindowHeaderBackground}" ButtonBackground="{DynamicResource Brush_PrimaryText}" BarBackground="{DynamicResource Brush_Accent}" Value="{Binding ProgressValue,Mode=TwoWay}" Maximum="1" IsHitTestVisible="{Binding CanReportProgress}"/>
    </Grid>
</UserControl>
